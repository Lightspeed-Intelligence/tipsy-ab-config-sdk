#!/bin/bash
# pre-push: block push if lint fails, then emulate a post-push CI watch.
set -uo pipefail

if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ]; then
  exit 0
fi

# Inner (self-wrapped) push: lint already ran in the outer invocation and the
# real push is happening now — let it through before doing any work again.
# The marker is an env var scoped to this process subtree, so it cannot leak
# into a later unrelated `git push` (no stale-flag risk).
if [ -n "${GIT_POSTPUSH:-}" ]; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel 2>/dev/null || echo .)"

errors=""

# Go vet — per workspace module (mirrors .github/workflows/go-test.yml, which
# gates on vet/test/proto-drift, not whole-tree gofmt). go.work is committed and
# is the single source of truth for the module list; parse it with sed rather
# than jq so the hook carries no extra dependency. go.work makes cross-module
# resolution work without GOWORK=off. gofmt runs in pre-commit (staged-only), so
# it isn't repeated tree-wide here where it would trip on pre-existing drift CI
# does not enforce.
if command -v go &>/dev/null; then
  go_modules=$(go work edit -json 2>/dev/null \
    | sed -n 's/.*"DiskPath": *"\([^"]*\)".*/\1/p')
  for m in $go_modules; do
    [ -f "$m/go.mod" ] || continue
    vet_out=$( cd "$m" && go vet ./... 2>&1 )
    if [ $? -ne 0 ]; then
      errors+="=== go vet ($m) ===\n${vet_out}\n\n"
    fi
  done
fi

# Python lint — ruff over the python SDK. Skipped silently when ruff isn't
# installed locally.
if [ -d "sdk/python" ] && command -v ruff &>/dev/null; then
  py_out=$(ruff check sdk/python/ 2>&1)
  if [ $? -ne 0 ]; then
    errors+="=== ruff check sdk/python/ ===\n${py_out}\n\n"
  fi
fi

if [ -n "$errors" ]; then
  echo -e "$errors" >&2
  exit 1
fi

echo "pre-push: all lint checks passed."

# ── post-push CI watch (self-wrapping) ──────────────────────────────────────
# git has no native post-push hook. We emulate one: on the OUTER push the
# GIT_POSTPUSH marker is absent, so we perform the real push ourselves (INNER),
# which re-enters this hook WITH the marker and is let through immediately at
# the top. Control then returns here and we block on the remote CI.
#
# Read the refspecs git handed us on stdin (one per line:
#   <local ref> <local sha> <remote ref> <remote sha>)
# and mirror them EXACTLY on the inner push, instead of assuming a single
# current-branch push. This keeps force-pushes, tag pushes, ref deletions
# (`git push origin :foo`) and multi-ref pushes (`git push --all`) working.
zero="0000000000000000000000000000000000000000"
refspecs=()
have_update=0          # at least one non-delete ref → CI watch is meaningful
non_ff_refs=()         # "remote_ref:remote_sha" for each non-fast-forward update

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${remote_ref:-}" ] && continue
  if [ "$local_sha" = "$zero" ]; then
    # Deletion: the refspec is ":<remote_ref>" (empty source).
    refspecs+=(":${remote_ref}")
  else
    refspecs+=("${local_ref}:${remote_ref}")
    have_update=1
    # Record non-fast-forward updates (remote has commits not contained in
    # local). We do NOT decide here whether to force — that is gated on
    # explicit user intent below, because a pre-push hook cannot see the outer
    # `--force` flag and must not infer it from topology.
    if [ "$remote_sha" != "$zero" ] \
       && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      non_ff_refs+=("${remote_ref}:${remote_sha}")
    fi
  fi
done

# Nothing on stdin → let the outer push proceed normally; nothing to wrap.
if [ "${#refspecs[@]}" -eq 0 ]; then
  exit 0
fi

# Deletions only → no CI to watch. Let the OUTER push perform the delete
# normally (no self-wrap needed) and return.
if [ "$have_update" -eq 0 ]; then
  exit 0
fi

remote_name="${1:-origin}"

# Force intent must be EXPLICIT, never inferred. A pre-push hook runs before the
# remote would reject a non-fast-forward push and is NOT told whether the outer
# command used `--force`, so treating "non-fast-forward" as "user wants to force"
# would silently rewrite remote history on an ordinary `git push` from a stale
# branch (rebase/reset/behind). We therefore only force-push when the user opts
# in via GIT_POSTPUSH_FORCE=1; otherwise the inner push runs as a plain push and
# a genuine non-fast-forward is rejected by the remote exactly as it would be
# without this hook.
force_lease_args=()
if [ -n "${GIT_POSTPUSH_FORCE:-}" ] && [ "${#non_ff_refs[@]}" -gt 0 ]; then
  # Pin the lease to the remote_sha git negotiated for this push (exact, no
  # fetch-or-die), so a concurrent remote advance still aborts the force.
  for rr in "${non_ff_refs[@]}"; do
    force_lease_args+=("--force-with-lease=${rr}")
  done
  echo "post-push: GIT_POSTPUSH_FORCE set — inner push will force ${#non_ff_refs[@]} non-fast-forward ref(s) with a pinned lease." >&2
elif [ "${#non_ff_refs[@]}" -gt 0 ]; then
  echo "post-push: ${#non_ff_refs[@]} non-fast-forward ref(s) detected; NOT forcing (set GIT_POSTPUSH_FORCE=1 to force). The inner push will be rejected by the remote if it is truly non-fast-forward." >&2
fi

# Capture the "new review activity" cut-off BEFORE the inner push updates the
# remote, then hand it to check-pr-ci.sh via GIT_POSTPUSH_CUTOFF. Sampling it
# inside that script would be too late: it runs only after the push, so a
# comment created in the gap between the remote update and the script start
# would have createdAt < a script-sampled cut-off and be missed. UTC 'Z' to
# match GitHub's createdAt lexical ordering.
export GIT_POSTPUSH_CUTOFF="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# The pre-push protocol does NOT expose the outer push's flags (--atomic,
# --signed, --push-option, --follow-tags, ...), so the inner push cannot mirror
# them verbatim. To avoid SILENTLY dropping the guarantee that matters most:
#   • --atomic is applied automatically whenever more than one refspec is being
#     pushed, so a multi-ref push keeps its all-or-nothing semantics instead of
#     degrading to partial success. (Single-ref pushes are atomic anyway.)
#   • GIT_POSTPUSH_PUSH_OPTS lets the caller forward any extra push options the
#     hook can't see, e.g.
#         GIT_POSTPUSH_PUSH_OPTS='--signed --push-option=ci.skip' git push
#     Tokens are split on whitespace (these git flags don't contain spaces).
extra_push_args=()
if [ "${#refspecs[@]}" -gt 1 ]; then
  extra_push_args+=("--atomic")
fi
if [ -n "${GIT_POSTPUSH_PUSH_OPTS:-}" ]; then
  # shellcheck disable=SC2206  # intentional word-splitting of the opt string
  extra_push_args+=(${GIT_POSTPUSH_PUSH_OPTS})
fi

echo "post-push: performing real push to '${remote_name}' (${refspecs[*]})${extra_push_args[*]+ [opts: ${extra_push_args[*]}]}..." >&2
# `${arr[@]+"${arr[@]}"}` is the parameter-expansion guard form: empty under
# `set -u` on bash 3.2 (the default /bin/bash on macOS), equivalent to
# `"${arr[@]}"` on bash >=4.4. A bare expansion of an empty array trips
# "unbound variable" on bash 3.2 and aborts the hook on every non-force push.
GIT_POSTPUSH=1 git push \
  ${force_lease_args[@]+"${force_lease_args[@]}"} \
  ${extra_push_args[@]+"${extra_push_args[@]}"} \
  "${remote_name}" "${refspecs[@]}"
push_rc=$?
if [ "$push_rc" -ne 0 ]; then
  echo "post-push: inner push failed (rc=${push_rc}) — not watching CI." >&2
  exit "$push_rc"
fi

# The inner push already updated the remote. The OUTER push that invoked this
# hook is now guaranteed to fail — either git's atomic ref protection rejects it
# ("remote rejected / cannot lock ref"), or the connection drops during the long
# CI watch (SIGPIPE / "connection closed"). Both are EXPECTED and HARMLESS: the
# push already succeeded via the inner push. Consequently the OUTER push's exit
# code does NOT reflect CI status — read the ✓/✗ report below for the verdict.
echo "post-push: ✔ push succeeded (remote updated by inner push)." >&2
echo "post-push:   any outer 'remote rejected' or 'connection closed' line below is expected — ignore it." >&2
echo "post-push:   the real verdict is the ✓/✗ report once CI finishes." >&2

# The inner push has already updated the remote. Block on CI, then report.
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
if [ -x "${repo_root}/scripts/check-pr-ci.sh" ]; then
  "${repo_root}/scripts/check-pr-ci.sh"
  ci_rc=$?
  # rc 2  = no PR / gh missing → non-fatal, fall through.
  # rc 1  = CI failed          → surface as failure.
  # rc 75 = CI passed but new review activity / unresolved threads remain →
  #         surface as failure too. Returning 0 here would let the outer push
  #         exit 0 and any tooling that only inspects exit status (agent
  #         loops, CI driver scripts) would silently miss the
  #         "address review feedback" stderr block.
  if [ "$ci_rc" -eq 1 ] || [ "$ci_rc" -eq 75 ]; then
    exit 1
  fi
  # rc 0 path: check-pr-ci.sh has already printed either the "nothing more to
  # do" terminator OR a Claude-targeted instruction block describing how to
  # fetch review comments and loop until terminal. Nothing to add here.
fi

# Reaching here means the real push already succeeded (inner). Returning 0 makes
# the OUTER push a no-op ("Everything up-to-date") — it does NOT push again.
exit 0
